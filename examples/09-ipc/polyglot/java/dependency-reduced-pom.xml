<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd">
  <modelVersion>4.0.0</modelVersion>
  <groupId>io.orionmesh.demo</groupId>
  <artifactId>orion-demo-java</artifactId>
  <version>0.1.0</version>
  <build>
    <plugins>
      <plugin>
        <artifactId>maven-shade-plugin</artifactId>
        <version>3.5.0</version>
        <executions>
          <execution>
            <id>pub</id>
            <phase>package</phase>
            <goals>
              <goal>shade</goal>
            </goals>
            <configuration>
              <finalName>orion-demo-pub</finalName>
              <transformers>
                <transformer>
                  <mainClass>io.orionmesh.demo.Pub</mainClass>
                </transformer>
              </transformers>
            </configuration>
          </execution>
          <execution>
            <id>sub</id>
            <phase>package</phase>
            <goals>
              <goal>shade</goal>
            </goals>
            <configuration>
              <finalName>orion-demo-sub</finalName>
              <transformers>
                <transformer>
                  <mainClass>io.orionmesh.demo.Sub</mainClass>
                </transformer>
              </transformers>
            </configuration>
          </execution>
          <execution>
            <id>js-pub</id>
            <phase>package</phase>
            <goals>
              <goal>shade</goal>
            </goals>
            <configuration>
              <finalName>orion-demo-js-pub</finalName>
              <transformers>
                <transformer>
                  <mainClass>io.orionmesh.demo.JsPub</mainClass>
                </transformer>
              </transformers>
            </configuration>
          </execution>
          <execution>
            <id>js-sub</id>
            <phase>package</phase>
            <goals>
              <goal>shade</goal>
            </goals>
            <configuration>
              <finalName>orion-demo-js-sub</finalName>
              <transformers>
                <transformer>
                  <mainClass>io.orionmesh.demo.JsSub</mainClass>
                </transformer>
              </transformers>
            </configuration>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>
  <properties>
    <maven.compiler.target>17</maven.compiler.target>
    <maven.compiler.source>17</maven.compiler.source>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
  </properties>
</project>
